# Default to LF for all text files; Git stores LF and Windows tools see LF.
# This avoids prettier flagging files as "needs reformat" after a fresh checkout
# on Windows when core.autocrlf is on.
* text=auto eol=lf

# Always-binary assets — never touch their bytes.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
